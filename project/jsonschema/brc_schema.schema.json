                        "$ref": "#/$defs/Contributor"
                    },
                    "type": [
                        "array",
                        "null"
                    ]
                },
                "country_publication": {
                    "description": "Human-readable country of publication, if available.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "country_publication_code": {
                    "description": "Country code for the publication venue, if applicable.",
