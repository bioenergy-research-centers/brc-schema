                    "description": "Location of the conference.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "conference_title": {
                    "description": "Title of the conference.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "conference_type": {
                    "description": "Code representing the type of conference-related work.",
